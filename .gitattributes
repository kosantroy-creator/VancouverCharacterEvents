# Normalize line endings to LF in the repository on every platform.
# Prevents Windows CRLF checkouts from breaking Prettier/ESLint.
* text=auto eol=lf

# Binary assets — never normalize.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.svg  text
*.woff  binary
*.woff2 binary
